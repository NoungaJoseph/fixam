{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fixam-backend-production.up.railway.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://fixam-backend-production.up.railway.app"
      },
      "hook": {
        "postPrebuild": "./eas-hooks/post-prebuild.js"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fixam-backend-production.up.railway.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://fixam-backend-production.up.railway.app"
      },
      "hook": {
        "postPrebuild": "./eas-hooks/post-prebuild.js"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
